{
  "name": "infoaxon-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-seo-files.mjs && vite build && node scripts/prerender.mjs",
    "preview": "vite preview",
    "server": "nodemon server/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run server\"",
    "server:prod": "node server/index.js",
    "prisma:generate": "prisma generate --schema server/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema server/prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema server/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "axios": "^1.7.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "framer-motion": "^11.2.10",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^5.2.1",
    "react-intersection-observer": "^9.10.3",
    "react-router-dom": "^6.23.1",
    "slugify": "^1.6.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14",
    "postcss": "^8.4.38",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1"
  },
  "prisma": {
    "seed": "node server/prisma/seed.js"
  }
}
