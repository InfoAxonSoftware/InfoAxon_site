generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  TO_ORDER
}
enum RuleLevel {
  REQUIRED
  RECOMMENDED
}
enum InquiryStatus {
  NEW
  READ
  RESOLVED
  ARCHIVED
}
enum InquiryPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}
enum QuotationStatus {
  NEW
  CONTACTED
  QUOTED
  APPROVED
  REJECTED
  COMPLETED
}

model AdminUser {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProductCategory {
  id           String    @id @default(cuid())
  name         String    @unique
  slug         String    @unique
  enabled      Boolean   @default(true)
  displayOrder Int       @default(0)
  products     Product[]
  rules        CompatibilityRule[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Product {
  id               String    @id @default(cuid())
  name             String    @unique
  slug             String    @unique
  categoryId       String
  category         ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  shortDescription String
  fullDescription  String?   @db.Text
  specifications   Json?
  compatibilityType String?
  price            Decimal   @db.Decimal(12, 2)
  warranty         String?
  stockQuantity    Int       @default(0)
  stockStatus      StockStatus @default(IN_STOCK)
  imageUrl         String?
  featured         Boolean   @default(false)
  enabled          Boolean   @default(true)
  displayOrder     Int       @default(0)
  rules            CompatibilityRule[] @relation("SuggestedProduct")
  compatibilityRules CompatibilityRule[] @relation("RuleProduct")
  alternativeFor   CompatibilityAlternative[]
  quotationItems   QuotationItem[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model SoftwarePackage {
  id            String    @id @default(cuid())
  solutionId    String?
  solution      Solution? @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  name          String    @unique
  slug          String    @unique
  startingPrice Decimal   @db.Decimal(12, 2)
  suitableFor   String
  summary       String
  supportPeriod String
  licenceNote   String?
  mostPopular   Boolean   @default(false)
  enabled       Boolean   @default(true)
  displayOrder  Int       @default(0)
  features      PackageFeature[]
  addons        PackageAddon[]
  quotations    QuotationRequest[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model PackageFeature {
  id          String @id @default(cuid())
  packageId   String
  package     SoftwarePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  text        String
  featured    Boolean @default(false)
  enabled     Boolean @default(true)
  displayOrder Int @default(0)
}

model PackageAddon {
  id          String @id @default(cuid())
  packageId   String
  package     SoftwarePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  text        String
  displayOrder Int @default(0)
}

model CompatibilityRule {
  id                     String @id @default(cuid())
  name                   String
  categoryId             String?
  category               ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  productId              String?
  product                Product? @relation("RuleProduct", fields: [productId], references: [id], onDelete: Restrict)
  suggestedProductId     String?
  suggestedProduct       Product? @relation("SuggestedProduct", fields: [suggestedProductId], references: [id], onDelete: SetNull)
  level                  RuleLevel
  message                String
  explanation            String
  allowOwnedConfirmation Boolean @default(false)
  enabled                Boolean @default(true)
  displayOrder           Int @default(0)
  alternatives           CompatibilityAlternative[]
}

model CompatibilityAlternative {
  ruleId    String
  productId String
  rule      CompatibilityRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  @@id([ruleId, productId])
}

model Solution {
  id String @id @default(cuid())
  slug String @unique
  title String
  shortTitle String?
  subtitle String?
  description String @db.Text
  icon String?
  imageUrl String?
  content Json?
  enabled Boolean @default(true)
  displayOrder Int @default(0)
  keyFeatures SolutionKeyFeature[]
  packages SoftwarePackage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SolutionKeyFeature {
  id String @id @default(cuid())
  solutionId String
  solution Solution @relation(fields: [solutionId], references: [id], onDelete: Cascade)
  number String
  title String
  description String @db.Text
  imageUrl String?
  enabled Boolean @default(true)
  displayOrder Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id String @id @default(cuid())
  slug String @unique
  title String
  category String?
  description String @db.Text
  imageUrl String?
  client String?
  demoUrl String?
  technologies Json?
  results Json?
  images Json?
  content Json?
  featured Boolean @default(false)
  enabled Boolean @default(true)
  displayOrder Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyInfo {
  id String @id @default("company")
  name String
  phone String?
  whatsapp String?
  email String?
  address String?
  socialLinks Json?
  footerDetails String?
  content Json?
  updatedAt DateTime @updatedAt
}

model WebsiteSetting {
  id String @id @default(cuid())
  key String @unique
  value Json
  type String @default("text")
  enabled Boolean @default(true)
  description String?
  updatedAt DateTime @updatedAt
}

model ErpKeyFeature {
  id String @id @default(cuid())
  number String
  title String
  description String
  imageUrl String?
  enabled Boolean @default(true)
  displayOrder Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactInquiry {
  id String @id @default(cuid())
  fullName String
  email String
  inquiryType String
  message String @db.Text
  status InquiryStatus @default(NEW)
  priority InquiryPriority @default(NORMAL)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuotationRequest {
  id String @id @default(cuid())
  customerName String
  businessName String
  phone String
  email String
  location String
  purchaseType String
  softwarePackageId String?
  softwarePackage SoftwarePackage? @relation(fields: [softwarePackageId], references: [id], onDelete: SetNull)
  softwareName String?
  softwarePrice Decimal @default(0) @db.Decimal(12, 2)
  estimatedTotal Decimal @db.Decimal(12, 2)
  notes String? @db.Text
  status QuotationStatus @default(NEW)
  items QuotationItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuotationItem {
  id String @id @default(cuid())
  quotationId String
  quotation QuotationRequest @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId String?
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  quantity Int
  unitPrice Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)
}

model Advertisement {
  id           String   @id @default(cuid())
  title        String?
  description  String?  @db.Text
  badge        String?
  imageUrl     String?
  ctaText      String?
  ctaLink      String?
  enabled      Boolean  @default(true)
  startDate    DateTime?
  endDate      DateTime?
  displayOrder Int      @default(0)
  fitMode      String   @default("contain")
  positionX    String   @default("center")
  positionY    String   @default("center")
  durationSeconds Int   @default(6)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
